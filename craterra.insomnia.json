			"parentId": "fld_conn",
			"method": "PUT",
			"url": "{{ _.base_url }}/albums/{{ _.albumId }}/connections/{{ _.connectionId }}",
			"headers": [
				{ "name": "Authorization", "value": "Bearer {{ _.token }}" },
				{ "name": "Content-Type", "value": "application/json" }
			],
			"body": {
				"mimeType": "application/json",
				"text": "{\n  \"type\": \"similar-to\",\n  \"note\": \"Updated note\"\n}"
			}
		},
		{
			"_id": "req_delete_conn",
			"_type": "request",
			"name": "Delete connection",
			"parentId": "fld_conn",
			"method": "DELETE",
			"url": "{{ _.base_url }}/albums/{{ _.albumId }}/connections/{{ _.connectionId }}",
			"headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
			"body": {}
		},

