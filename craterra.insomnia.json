		{
			"_id": "fld_albums",
			"_type": "request_group",
			"name": "Albums",
			"parentId": "wrk_craterra",
			"sortKey": 2
		},
		{
			"_id": "fld_io",
			"_type": "request_group",
			"name": "Import / Export",
			"parentId": "wrk_craterra",
