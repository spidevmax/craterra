			"parentId": "fld_conn",
			"method": "POST",
			"url": "{{ _.base_url }}/albums/{{ _.albumId }}/connections",
			"headers": [
				{ "name": "Authorization", "value": "Bearer {{ _.token }}" },
				{ "name": "Content-Type", "value": "application/json" }
			],
			"body": {
				"mimeType": "application/json",
				"text": "{\n  \"targetAlbumId\": \"PASTE_TARGET_ALBUM_ID\",\n  \"type\": \"influences\",\n  \"note\": \"Huge influence on the genre\"\n}"
			}
		},
		{
			"_id": "req_update_conn",
			"_type": "request",
