		{
			"_id": "req_register",
			"_type": "request",
			"name": "Register",
			"parentId": "fld_auth",
			"method": "POST",
			"url": "{{ _.base_url }}/auth/register",
			"headers": [],
			"body": {
				"mimeType": "multipart/form-data",
				"params": [
					{ "name": "name", "value": "Test User" },
					{ "name": "email", "value": "test@craterra.com" },
					{ "name": "password", "value": "test1234" }
				]
			}
		},
		{
			"_id": "req_login",
			"_type": "request",
			"name": "Login → copy token to env",
			"parentId": "fld_auth",
			"method": "POST",
			"url": "{{ _.base_url }}/auth/login",
			"headers": [{ "name": "Content-Type", "value": "application/json" }],
			"body": {
				"mimeType": "application/json",
				"text": "{\n  \"email\": \"admin@craterra.com\",\n  \"password\": \"admin1234\"\n}"
			}
		},

		{
			"_id": "req_get_albums",
			"_type": "request",
			"name": "Get my albums",
			"parentId": "fld_albums",
			"method": "GET",
			"url": "{{ _.base_url }}/albums",
			"headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
			"body": {}
		},
		{
			"_id": "req_get_album",
			"_type": "request",
			"name": "Get album by ID",
			"parentId": "fld_albums",
			"method": "GET",
			"url": "{{ _.base_url }}/albums/{{ _.albumId }}",
			"headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
			"body": {}
		},
		{
			"_id": "req_post_album",
			"_type": "request",
			"name": "Create album",
			"parentId": "fld_albums",
			"method": "POST",
			"url": "{{ _.base_url }}/albums",
			"headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
			"body": {
				"mimeType": "multipart/form-data",
				"params": [
					{ "name": "title", "value": "OK Computer" },
					{ "name": "artists[]", "value": "Radiohead" },
					{ "name": "format", "value": "LP" },
					{ "name": "releaseDate", "value": "1997-05-21" },
					{ "name": "labels[]", "value": "Parlophone" },
					{ "name": "genres[]", "value": "Alternative Rock" },
					{ "name": "genres[]", "value": "Art Rock" },
					{ "name": "rating", "value": "10" },
					{ "name": "favourite", "value": "true" },
					{ "name": "releaseCountry", "value": "United Kingdom" },
					{ "name": "externalUrl", "value": "https://music.apple.com/album/ok-computer" }
				]
			}
		},
		{
			"_id": "req_put_album",
			"_type": "request",
			"name": "Update album",
			"parentId": "fld_albums",
			"method": "PUT",
			"url": "{{ _.base_url }}/albums/{{ _.albumId }}",
			"headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
			"body": {
				"mimeType": "multipart/form-data",
				"params": [{ "name": "rating", "value": "9" }, { "name": "favourite", "value": "false" }]
			}
		},
		{
			"_id": "req_delete_album",
			"_type": "request",
			"name": "Delete album",
			"parentId": "fld_albums",
			"method": "DELETE",
			"url": "{{ _.base_url }}/albums/{{ _.albumId }}",
			"headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
			"body": {}
		},
		{
			"_id": "req_graph",
			"_type": "request",
			"name": "Get album graph",
			"parentId": "fld_albums",
			"method": "GET",
			"url": "{{ _.base_url }}/albums/graph/all",
			"headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
			"body": {}
		},

		{
			"_id": "req_import",
			"_type": "request",
			"name": "Import from Notion CSV",
			"parentId": "fld_io",
			"method": "POST",
			"url": "{{ _.base_url }}/albums/import",
			"headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
			"body": {
				"mimeType": "multipart/form-data",
				"params": [{ "name": "file", "fileName": "/path/to/your-notion-export.csv", "type": "file" }]
			}
		},
		{
			"_id": "req_export",
			"_type": "request",
			"name": "Export library as CSV",
			"parentId": "fld_io",
